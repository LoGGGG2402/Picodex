{
  "name": "pocodex",
  "version": "0.3.0",
  "description": "Serve the real Codex desktop webview in a browser and proxy the host runtime.",
  "keywords": [
    "browser",
    "cli",
    "codex",
    "macos",
    "openai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/davej/pocodex"
  },
  "bin": {
    "pocodex": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsgo -p tsconfig.json && npm run build:static",
    "build:static": "mkdir -p dist/images && cp src/assets/styles/pocodex.css dist/pocodex.css && cp src/assets/images/import.svg dist/images/import.svg",
    "check": "npm run typecheck",
    "dev": "tsx src/cli.ts",
    "prepare": "simple-git-hooks",
    "prepack": "npm run build",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@electron/asar": "^4.1.0",
    "mime-types": "^3.0.2",
    "node-pty": "^1.1.0",
    "plist": "^3.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.5",
    "@types/plist": "^3.0.5",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260312.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check"
  },
  "engines": {
    "node": ">=24"
  }
}
